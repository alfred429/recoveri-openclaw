# Recoveri .gitignore — What does NOT belong in version control

# === Secrets & Credentials ===
*.env
.env.*
secrets/
*.key
*.pem
*.crt
*.p12
*token*
*credential*
!governance/  # Do not ignore governance folder

# === Runtime Data ===
operations-logs/
*.jsonl
*.log
*.tmp
*.bak
*.swp

# === Session Data ===
sessions/
.openclaw/
workspace-*/

# === OS & Editor ===
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# === Binary Documents (these live in Drive, not Git) ===
*.pdf
*.docx
*.xlsx
*.pptx
*.zip
*.tar.gz

# === Node/Python artifacts ===
node_modules/
__pycache__/
*.pyc
venv/
.venv/

# === Backups (created by deploy scripts) ===
backups/
*-backup-*
*.pre-*
